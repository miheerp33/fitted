PORT=3001
FRONTEND_URL=http://localhost:5173

# Whitelisted emails have unlimited API calls (comma-separated)
WHITELISTED_EMAILS=you@example.com

# Daily limits for non-whitelisted users (per endpoint)
DAILY_LIMIT_UPLOAD=3
DAILY_LIMIT_RECOMMEND=5
DAILY_LIMIT_MOODBOARD=5

# Modal AI (all inference runs on Modal) - deploy with: cd modal_app && modal deploy app.py
MODAL_AI_URL=your_modal_endpoint_url

# OpenWeatherMap - https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# Supabase - https://supabase.com/dashboard
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
